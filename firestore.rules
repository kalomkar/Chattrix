rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getSqlId() {
      let mappingPath = /databases/$(database)/documents/mappings/$(request.auth.uid);
      return exists(mappingPath) ? get(mappingPath).data.sqlId : request.auth.uid;
    }

    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || getSqlId() == userId);
    }

    function isChatParticipant(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId));
      let sqlId = getSqlId();
      return isSignedIn() && (request.auth.uid in chat.data.participants || sqlId in chat.data.participants);
    }

    // Mappings for ID bridging
    match /mappings/{fbUid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == fbUid;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      // User contacts subcollection
      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || getSqlId() in resource.data.participants);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants || getSqlId() in resource.data.participants) && (
        request.resource.data.lastMessage.senderId == request.auth.uid || 
        request.resource.data.lastMessage.senderId == getSqlId() ||
        request.resource.data.lastMessage.senderId == 'nova-ai-bot'
      );
    }

    // Messages
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isChatParticipant(chatId);
      allow create: if isChatParticipant(chatId) && (
        request.resource.data.senderId == request.auth.uid || 
        request.resource.data.senderId == getSqlId() ||
        (request.resource.data.senderId == 'nova-ai-bot' && 'nova-ai-bot' in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
      );
      allow update: if isChatParticipant(chatId);
      allow delete: if isChatParticipant(chatId) && (
        resource.data.senderId == request.auth.uid || 
        (resource.data.disappearing.enabled == true) ||
        (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.groupMetadata.admins)
      );
    }

    // Stories (Chattrix Stories)
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isOwner(request.resource.data.uid);
      allow update: if isOwner(resource.data.uid) || (isSignedIn() && (request.auth.uid in resource.data.views || getSqlId() in resource.data.views));
      allow delete: if isOwner(resource.data.uid);
    }

    // Scheduled Messages
    match /scheduled_messages/{messageId} {
      allow read, delete: if isOwner(resource.data.senderId);
      allow create: if isOwner(request.resource.data.senderId);
      allow update: if isOwner(resource.data.senderId) && (
        resource.data.status == 'pending' || resource.data.status == 'failed'
      );
    }
  }
}
